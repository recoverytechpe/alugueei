# Copie para .env.test e preencha. NUNCA commite .env.test (já está no .gitignore por padrão via .env*).
#
# URL base do app rodando localmente (bun run dev)
E2E_BASE_URL=http://localhost:8080

# Credenciais de um usuário tenant de teste já cadastrado no Lovable Cloud
E2E_TENANT_EMAIL=tenant.e2e@exemplo.com
E2E_TENANT_PASSWORD=troque-esta-senha

# UUID de um imóvel publicado que o tenant ainda NÃO desbloqueou
E2E_PROPERTY_ID=00000000-0000-0000-0000-000000000000

# Backend (Lovable Cloud) — use os mesmos valores do .env do projeto
SUPABASE_URL=https://vvsoctvmctomovcebvli.supabase.co

# Service role: necessário APENAS local para mockar webhook do MP (status=paid)
# e forçar expiração. NUNCA suba para CI público nem commite.
# No Lovable Cloud essa chave não é exposta — peça ao responsável pelo backend.
SUPABASE_SERVICE_ROLE_KEY=cole-aqui-apenas-local
